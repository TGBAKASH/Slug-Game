# Slugterra Environment Variables

# MongoDB connection string (get from MongoDB Atlas → Connect → Drivers)
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/slugterra?retryWrites=true&w=majority

# Database name (default: slugterra)
DB_NAME=slugterra

# Port (Render sets this automatically)
PORT=3000

# API secret for signed requests (Render auto-generates via render.yaml)
API_SECRET=your-secret-here
